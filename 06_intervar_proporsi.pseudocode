START

INPUT p_hat
INPUT n
INPUT alpha

IF p_hat < 0 OR p_hat > 1 THEN
    OUTPUT "Error: proporsi harus antara 0 dan 1"
ELSE

    IF alpha = 10% THEN
        z ← 1.645
    ELSE IF alpha = 5% THEN
        z ← 1.96
    ELSE
        OUTPUT "Alpha tidak valid"
        STOP
    END IF

    margin_error ← z * sqrt((p_hat*(1-p_hat))/n)

    batas_bawah ← p_hat - margin_error
    batas_atas ← p_hat + margin_error

    OUTPUT batas_bawah
    OUTPUT batas_atas
END IF

END
